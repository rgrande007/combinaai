rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Sessões ──────────────────────────────────────────────
    // Apenas usuários Google autenticados criam sessões.
    // Atualizar: criador (por email) ou qualquer autenticado alterando só summary.
    // Excluir: somente o criador.
    match /sessions/{sessionId} {
      allow read   : if request.auth != null;
      allow create : if request.auth != null && request.auth.token.email != null;
      allow update : if request.auth != null && (
        request.auth.token.email == resource.data.createdBy ||
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['summary'])
      );
      allow delete : if request.auth != null
        && request.auth.token.email == resource.data.createdBy;

      // ── Respostas (por sessão) ────────────────────────────
      // Leitura: qualquer autenticado (Google ou anônimo).
      // Escrita Google : doc ID = email do usuário.
      // Escrita anônima: uid armazenado no documento deve coincidir com o uid auth.
      // Deleção: dono da resposta OU criador da sessão.
      match /responses/{responseId} {
        allow read  : if request.auth != null;
        // Google: doc ID == email do usuário
        // Anônimo: doc ID == "anon_" + uid do usuário
        allow create, update : if request.auth != null && (
          request.auth.token.email == responseId ||
          responseId == ('anon_' + request.auth.uid)
        );
        // Dono pode deletar a própria resposta; criador da sessão pode deletar qualquer uma
        allow delete : if request.auth != null && (
          request.auth.token.email == responseId ||
          responseId == ('anon_' + request.auth.uid) ||
          request.auth.token.email == get(/databases/$(database)/documents/sessions/$(sessionId)).data.createdBy
        );
      }
    }

    // ── Collection group — "Sessões em que participei" ────────
    // Permite que o usuário Google leia APENAS as próprias respostas
    // em todas as sessões (doc ID == email do usuário).
    // Usuários anônimos não usam essa query.
    match /{path=**}/responses/{responseId} {
      allow read : if request.auth != null
        && request.auth.token.email != null
        && request.auth.token.email == responseId;
    }

  }
}
